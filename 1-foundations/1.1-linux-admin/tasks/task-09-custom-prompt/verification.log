## 🔍 Verifying custom PS1 prompt config was appended to ~/.bashrc

> **Timestamp:** `2026-06-15 22:35:32`

### 01. `tail -20 ~/.bashrc`

```bash
tail -20 ~/.bashrc
```

**Output:**

```text
fi

# --- Custom Prompt Configuration ---

# Function to get current git branch
parse_git_branch() {
    git branch 2>/dev/null | sed -n '/\* /s///p'
}

# Function to display git branch in prompt (only if in a git repo)
git_branch_prompt() {
    local branch
    branch=$(parse_git_branch)
    if [ -n "$branch" ]; then
        echo " (\033[33m${branch}\033[0m)"
    fi
}

# Set the prompt
export PS1='\[\033[01;32m\]\u\[\033[00m\]@\[\033[01;36m\]\h\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]$(git_branch_prompt)\$ '
```


